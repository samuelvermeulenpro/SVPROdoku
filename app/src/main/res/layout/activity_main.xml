<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="28dp">

        <!-- Titre -->
        <ImageView
            android:layout_width="170dp"
            android:layout_height="170dp"
            android:layout_marginBottom="4dp"
            android:src="@drawable/ic_launcher"
            android:textColor="#1A237E" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="24sp"
            android:letterSpacing="0.3"
            android:textColor="#37474F"
            android:textStyle="bold"
            android:layout_marginBottom="28dp"/>

        <!-- ══ Bandeau Reprendre ══ -->
        <LinearLayout
            android:id="@+id/cardResume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_resume"
            android:padding="16dp"
            android:layout_marginBottom="24dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/resume_title"
                android:textSize="11sp"
                android:textColor="#78909C"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvResumeInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#1A237E"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnResume"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:text="@string/resume_button"
                android:textSize="14sp"
                android:backgroundTint="#1565C0"/>
        </LinearLayout>

        <!-- ══ Classic ══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/variant_classic"
            android:textSize="11sp"
            android:textColor="#78909C"
            android:textAllCaps="true"
            android:letterSpacing="0.12"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btnEasy"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/difficulty_easy"
                android:textSize="13sp"
                android:backgroundTint="#1565C0"
                android:layout_marginEnd="6dp"/>

            <Button
                android:id="@+id/btnMedium"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/difficulty_medium"
                android:textSize="13sp"
                android:backgroundTint="#283593"
                android:layout_marginEnd="6dp"/>

            <Button
                android:id="@+id/btnHard"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/difficulty_hard"
                android:textSize="13sp"
                android:backgroundTint="#1A237E"/>
        </LinearLayout>

        <!-- ══ Serpentart ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_serpent"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/variant_serpentart"
                    android:textSize="13sp"
                    android:textColor="#1A237E"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/serpentart_desc"
                    android:textSize="11sp"
                    android:textColor="#5C6BC0"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <Button
                    android:id="@+id/btnSerpEasy"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/difficulty_easy"
                    android:textSize="13sp"
                    android:backgroundTint="#3949AB"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/btnSerpMedium"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/difficulty_medium"
                    android:textSize="13sp"
                    android:backgroundTint="#303F9F"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/btnSerpHard"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/difficulty_hard"
                    android:textSize="13sp"
                    android:backgroundTint="#1A237E"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
